# ydbdoc-review — local development environment
# Copy this file to .env and fill in real values. .env is gitignored.

# --- Yandex AI Studio (required for translation/critic) ---
# Folder id (b1…), API key (a.k.a. Secret key, AQVN…)
YDBDOC_YC_FOLDER_ID=
YDBDOC_YC_API_KEY=

# Legacy alternatives (also supported, first non-empty wins):
# YANDEX_CLOUD_FOLDER_DOC_REVIEW=
# YANDEX_CLOUD_API_KEY_DOC_REVIEW=
# YANDEX_CLOUD_FOLDER=
# YANDEX_CLOUD_API_KEY=

# --- LLM behavior overrides (optional) ---
# YDBDOC_LLM_TEMPERATURE=0.1
# YDBDOC_LLM_MAX_TOKENS=8000
# YDBDOC_LLM_TIMEOUT_S=120

# --- Model provider (optional; default yandex_cloud) ---
# YDBDOC_MODEL_PROVIDER=yandex_cloud
# YDBDOC_MODEL_PROVIDER=eliza
# ELIZA_API_ROOT=https://api.eliza.yandex.net
# ELIZA_OAUTH_TOKEN=          # env only — never CLI; not committed
# YDBDOC_MODEL_TRANSLATE=deepseek-v4-flash
# YDBDOC_MODEL_CHECK=gpt-oss-120b
# YDBDOC_ELIZA_CA_BUNDLE=/etc/ssl/certs/YandexInternalCA.pem
# Do NOT set REQUESTS_CA_BUNDLE to internal CA only — breaks api.github.com.
# Eliza merges this PEM with certifi automatically.
# YDBDOC_LLM_RETRIES_RATE_LIMIT_MAX_ATTEMPTS=8
# YDBDOC_LLM_RETRIES_RATE_LIMIT_BACKOFF_INITIAL_S=10
# YDBDOC_ELIZA_TRANSLATE_FALLBACKS=gpt-oss-120b,gpt-oss-20b
# YDBDOC_ELIZA_CHECK_FALLBACKS=gpt-oss-20b

# --- Model selection (optional, override config/default.yaml) ---
# YDBDOC_LLM_MODELS_TRANSLATE_PRIMARY=yandexgpt-5.1
# YDBDOC_LLM_MODELS_TRANSLATE_FALLBACKS=yandexgpt-5-pro,deepseek-v32
# YDBDOC_LLM_MODELS_CRITIC_PRIMARY=deepseek-v32
# YDBDOC_LLM_MODELS_CRITIC_FALLBACKS=yandexgpt-5.1,yandexgpt-5-pro

# --- Translation tuning (optional) ---
# YDBDOC_TRANSLATION_SEGMENTS_PER_BATCH_CHARS=4000

# --- GitHub (local PR operations; ydb CI uses job GITHUB_TOKEN only) ---
# GITHUB_TOKEN=ghp_...
# GITHUB_PUSH_TOKEN=   # optional override for push; not set in ydb doc_translate CI
# YDBDOC_PUSH_PAT=     # legacy alias → GITHUB_PUSH_TOKEN in Docker entrypoint

# --- Phase K ops (ACL / daily ₽ / transcripts in YDB) ---
# YDBDOC_ALLOWED_ACTORS=sintjuri
# YDBDOC_DAILY_BUDGET_RUB=5000
# YDBDOC_TRANSCRIPT_BACKEND=ydb
# YDBDOC_YDB_SA_KEY_FILE=/path/to/sa_key.json
# YDB_SA_KEY=   # alternative: full JSON of SA key (CI secret)
# YDBDOC_YDB_ENDPOINT=grpcs://ydb.serverless.yandexcloud.net:2135
# YDBDOC_YDB_DATABASE=/ru-central1/b1g7gqj2vnq67gjseuva/etns0641qf73btm7j21k
# YDBDOC_SKIP_OPS_GATES=1   # local tests only
# After S3 quota is raised:
# YDBDOC_TRANSCRIPT_BACKEND=s3
# YDBDOC_S3_ACCESS_KEY_ID=
# YDBDOC_S3_SECRET_ACCESS_KEY=
# YDBDOC_S3_BUCKET=ydb-prs-translations-context
