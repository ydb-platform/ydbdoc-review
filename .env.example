# ydbdoc-review — local development environment
# Copy this file to .env and fill in real values. .env is gitignored.

# --- Yandex AI Studio (required for translation/critic) ---
# Folder id (b1…), API key (a.k.a. Secret key, AQVN…)
YDBDOC_YC_FOLDER_ID=
YDBDOC_YC_API_KEY=

# Legacy alternatives (also supported, first non-empty wins):
# YANDEX_CLOUD_FOLDER_DOC_REVIEW=
# YANDEX_CLOUD_API_KEY_DOC_REVIEW=
# YANDEX_CLOUD_FOLDER=
# YANDEX_CLOUD_API_KEY=

# --- LLM behavior overrides (optional) ---
# YDBDOC_LLM_TEMPERATURE=0.1
# YDBDOC_LLM_MAX_TOKENS=8000
# YDBDOC_LLM_TIMEOUT_S=120

# --- Model selection (optional, override config/default.yaml) ---
# YDBDOC_LLM_MODELS_TRANSLATE_PRIMARY=yandexgpt-5.1
# YDBDOC_LLM_MODELS_TRANSLATE_FALLBACKS=yandexgpt-5-pro,deepseek-v32
# YDBDOC_LLM_MODELS_CRITIC_PRIMARY=deepseek-v32
# YDBDOC_LLM_MODELS_CRITIC_FALLBACKS=yandexgpt-5.1,yandexgpt-5-pro

# --- Translation tuning (optional) ---
# YDBDOC_TRANSLATION_SEGMENTS_PER_BATCH_CHARS=4000

# --- GitHub (local PR operations; ydb CI uses job GITHUB_TOKEN only) ---
# GITHUB_TOKEN=ghp_...
# GITHUB_PUSH_TOKEN=   # optional override for push; not set in ydb doc_translate CI
# YDBDOC_PUSH_PAT=     # legacy alias → GITHUB_PUSH_TOKEN in Docker entrypoint
