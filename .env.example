# Yandex AI Studio / Yandex Cloud Foundation Models (OpenAI-compatible endpoint).
# Folder (приоритет: DOC_REVIEW-имена для CI, затем общие YC_*).
# YANDEX_CLOUD_FOLDER_DOC_REVIEW=b1g08jt28oei79r901r5
# API key:
# YANDEX_CLOUD_API_KEY_DOC_REVIEW=AQVNXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Допустимы без суффикса: YANDEX_CLOUD_FOLDER / YANDEX_CLOUD_API_KEY или YC_FOLDER_ID / YC_API_KEY.
# YANDEX_CLOUD_FOLDER=b1g08jt28oei79r901r5
# YANDEX_CLOUD_API_KEY=AQVNXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# YANDEX_CLOUD_BASE_URL=https://ai.api.cloud.yandex.net/v1

# Другой OpenAI-compatible провайдер (OpenAI, Azure, vLLM, LiteLLM, …):
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-...
# YDBDOC_MODEL_CHECK=gpt-4o-mini
# YDBDOC_MODEL_TRANSLATE=gpt-4o

# Модели: правьте ydbdoc-review.toml в корне репо / в образе, либо встроенный
# src/ydbdoc_review/ydbdoc-review.toml; иначе env:
# YDBDOC_MODEL_CHECK=...
# Переводчик (A/B с yandexgpt-5.1): slug из Model gallery, например:
# YDBDOC_MODEL_TRANSLATE=deepseek-v3.2/latest
# YDBDOC_MODEL_TRANSLATE=deepseek-v4-flash
# YDBDOC_CONFIG=/absolute/path/to/custom.toml
# YDBDOC_FM_SKIP_RESPONSES_API=1   # optional: только chat.completions
# Быстрый выключатель без пересборки Docker:
# YDBDOC_REVIEW_ENABLED=false
# YDBDOC_MODEL_COMPLETION_TOKEN_CEILING=32768  # optional: cap completion tokens (DeepSeek/Qwen FM ≤32768)

# Self-check + repair: критик сравнивает RU↔EN, при «НЕ ПРИНИМАТЬ» fix-diff,
# затем повторная валидация переводчиком. Отчёт + эвристики — комментарий в PR.
# Коммит создаётся **всегда**, CI всегда зелёный — решение о мерже за пользователем.
# YDBDOC_TRANSLATION_SELF_CHECK=true
# YDBDOC_TRANSLATION_REPAIR=true   # false — только compare + heuristics, без fix-diff
# YDBDOC_MODEL_TRANSLATION_VERIFY=qwen3.6-35b-a3b
# YDBDOC_MODEL_VERIFY_FALLBACKS=qwen3-235b-a22b/latest,deepseek-v3.2/latest
# YDBDOC_QA_MAX_INPUT_CHARS=55000        # per-document cap for compare/fix calls
# YDBDOC_QA_MAX_OUTPUT_TOKENS=16384      # output budget for QA calls
# YDBDOC_HEURISTICS_MAX_INPUT_CHARS=40000  # cap for heuristics LLM call (rules from prompts/09)

# Analyze batch:
# YDBDOC_ANALYZE_TRUNCATE_CHARS=8000     # cap ru/en body in each analyze batch
# YDBDOC_ANALYZE_DIFF_MAX=500000         # cap ru_diff_vs_base / en_diff_vs_base in analyze JSON
# YDBDOC_ANALYZE_MAX_JSON_CHARS=24000    # max chars of {"pairs":...} per check-model call

# GitHub (local: https://github.com/settings/tokens — repo scope for push + PR comment)
GITHUB_TOKEN=
# Опционально: отдельный PAT для push (например в ветку форка); пусто = как GITHUB_TOKEN
# GITHUB_PUSH_TOKEN=
