# Yandex AI Studio / Yandex Cloud Foundation Models (OpenAI-compatible endpoint).
# Folder (приоритет: DOC_REVIEW-имена для CI, затем общие YC_*).
# YANDEX_CLOUD_FOLDER_DOC_REVIEW=b1g08jt28oei79r901r5
# API key:
# YANDEX_CLOUD_API_KEY_DOC_REVIEW=AQVNXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Допустимы без суффикса: YANDEX_CLOUD_FOLDER / YANDEX_CLOUD_API_KEY или YC_FOLDER_ID / YC_API_KEY.
# YANDEX_CLOUD_FOLDER=b1g08jt28oei79r901r5
# YANDEX_CLOUD_API_KEY=AQVNXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# YANDEX_CLOUD_BASE_URL=https://ai.api.cloud.yandex.net/v1

# Другой OpenAI-compatible провайдер (OpenAI, Azure, vLLM, LiteLLM, …):
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-...
# YDBDOC_MODEL_CHECK=gpt-4o-mini
# YDBDOC_MODEL_TRANSLATE=gpt-4o
# (каталог Yandex не нужен, если hostname не *.yandex.net)

# Модели: правьте ydbdoc-review.toml в корне репо / в образе, либо встроенный src/ydbdoc_review/ydbdoc-review.toml; иначе env:
# YDBDOC_MODEL_CHECK=...
# YDBDOC_MODEL_TRANSLATE=...
# YDBDOC_CONFIG=/absolute/path/to/custom.toml
# YDBDOC_FM_SKIP_RESPONSES_API=1   # optional: only chat.completions
# Быстрый выключатель без пересборки Docker (в CI задайте vars/secrets):
# YDBDOC_REVIEW_ENABLED=false
# YDBDOC_MAX_DIFF_CHARS=120000   # optional: max chars of git diff in diff-based translate mode
# YDBDOC_TRANSLATE_MAX_OUTPUT_TOKENS=0   # optional: 0 = default ceiling (~1M); lower if API rejects
# YDBDOC_TRANSLATE_CHUNK_CHARS=14000     # optional: split long markdown into fragments (UTF-8 chars); min 2048
# Self-check перевода: в образе правьте ydbdoc-review.toml ([feature].translation_self_check, [models].translation_verify).
# Env — переопределение без пересборки образа (удобно в GitHub Actions vars):
# YDBDOC_TRANSLATION_SELF_CHECK=true
# YDBDOC_MODEL_TRANSLATION_VERIFY=...
# YDBDOC_TRANSLATION_SELF_CHECK_MAX_INPUT_CHARS=40000   # optional: per-document cap sent to verify model
# YDBDOC_TRANSLATION_SELF_CHECK_MAX_OUTPUT_TOKENS=8192  # optional: completion budget for verify
# YDBDOC_TRANSLATION_SELF_CHECK_MAX_TOTAL_CHARS=18000   # optional: max chars for whole verify block in comment
# YDBDOC_ANALYZE_TRUNCATE_CHARS=8000  # optional: cap ru/en body in each analyze batch
# YDBDOC_ANALYZE_DIFF_MAX=500000      # optional: cap ru_diff_vs_base / en_diff_vs_base in analyze JSON
# YDBDOC_ANALYZE_MAX_JSON_CHARS=24000  # optional: max chars of {"pairs":...} per check-model call (batching)

# GitHub (local: https://github.com/settings/tokens — repo scope for push + PR comment)
GITHUB_TOKEN=
# Опционально: отдельный PAT для push (например в ветку форка); пусто = как GITHUB_TOKEN
# GITHUB_PUSH_TOKEN=
